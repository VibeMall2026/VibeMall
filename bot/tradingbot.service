[Unit]
Description=VibeMall Trading Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/vibemall
Environment=PYTHONPATH=/var/www/vibemall
ExecStart=/var/www/vibemall/venv/bin/python -m bot.main
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
