DEBUG=False
SECRET_KEY=your-secret-key-here
DATABASE_URL=postgresql://user:password@host/dbname
ALLOWED_HOSTS=your-app-name.onrender.com,*.railway.app,localhost
SITE_URL=https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=VibeMall <your-email@gmail.com>

# ==============================
# ENVIRONMENT VALIDATION
# ==============================
# On Django startup, the application validates environment variables:
# - CRITICAL: Must be set for app to function (errors will be logged)
# - IMPORTANT: Should be configured for production (warnings if missing)
# - OPTIONAL: Have sensible defaults (info logged if configured)
#
# Check Django logs for validation messages:
#   [CRITICAL] Missing required environment variables: ...
#   [WARNING] Missing important environment variables: ...
#   [INFO] Optional environment variables configured: ...
#
# Configuration guide: See ENV_CONFIGURATION.md
